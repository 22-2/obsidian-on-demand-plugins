{
    "name": "on-demand-plugins",
    "type": "module",
    "version": "3.4.5",
    "description": "Lazy load plugins by caching their commands. Plugins are enabled on-demand when you trigger their commands (or open specific views), keeping startup fast.",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "typecheck": "tsc6 -noEmit -skipLibCheck",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:install-browsers": "playwright install --with-deps",
        "build": "pnpm run typecheck && pnpm run build:nocheck",
        "build:nocheck": "node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "test": "vitest",
        "lint": "pnpm exec eslint ./src",
        "format": "pnpm run lint --fix && pnpm exec prettier --editorconfig --write ./src && pnpx organize-imports-cli tsconfig.json",
        "release": "pnpm dlx semantic-release",
        "release:dry": "pnpm release --dry-run"
    },
    "keywords": [],
    "author": "22-2",
    "repository": "https://github.com/22-2/obsidian-on-demand-plugins.git",
    "license": "MIT",
    "dependencies": {
        "async-mutex": "^0.5.0",
        "loglevel": "^1.9.2",
        "monkey-around": "^3.0.0",
        "p-event": "^7.1.0",
        "p-queue": "^9.3.1",
        "p-timeout": "^7.0.1",
        "p-wait-for": "^6.0.0",
        "store2": "^2.14.4"
    },
    "devDependencies": {
        "@22-2/esbuild-plugin-obsidian-copy": "github:22-2/esbuild-plugin-obsidian-copy#3677bb62f4af684968629eb8fc508260240fb916",
        "@eslint/js": "^10.0.1",
        "@obsidian-typings/obsidian-public-latest": "^6.22.0",
        "@playwright/test": "^1.59.1",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/exec": "^7.1.0",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.9",
        "@semantic-release/release-notes-generator": "^14.1.1",
        "@types/node": "^26.1.1",
        "@vitest/ui": "^4.1.10",
        "conventional-changelog-conventionalcommits": "^10.2.1",
        "esbuild": "0.28.1",
        "eslint": "^10.6.0",
        "eslint-plugin-obsidianmd": "^0.4.1",
        "globals": "^17.7.0",
        "jiti": "^2.7.0",
        "moment": "^2.30.1",
        "obsidian-e2e-toolkit": "github:22-2/obsidian-e2e-toolkit#1.0.5",
        "obsidian-typings": "^5.18.0",
        "playwright": "^1.59.1",
        "prettier": "^3.9.5",
        "typescript": "npm:@typescript/typescript6@6.0.2",
        "typescript-eslint": "^8.63.0",
        "vitest": "^4.1.10"
    }
}
