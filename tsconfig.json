{
    "compilerOptions": {
        // Project Structure
        "paths": {
            "*": ["./*"]
        },

        // Input / Output
        "noEmit": true,
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "verbatimModuleSyntax": true,

        
        // Type Checking
        "strict": true,
        "erasableSyntaxOnly": true,

        // Type Definitions
        "types": ["obsidian-typings"],
        "lib": ["DOM", "ESNext"]
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}
