{
    "compilerOptions": {
        // Project structure
        "paths": {
            "/*": ["./*"],
            "src/*": ["./src/*"]
        },

        // Module system
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,

        // Type checking
        "strict": true,
        "erasableSyntaxOnly": true,

        // Type definitions
        "types": ["obsidian-typings"],
        "lib": ["DOM", "ESNext"]
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}
